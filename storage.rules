rules_version = '2';

// Production baseline (draft — not deployed until explicitly released).
// Catalog art: public read, no client upload. Paths: catalog/series/*, catalog/figures/*.
// See docs/FIREBASE_LOCAL_SETUP.md for deploy notes.

service firebase.storage {
  match /b/{bucket}/o {

    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Reserved for future per-user media (shelf photos are local-only today).
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
