<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/on_display_widget_background"
    android:orientation="vertical"
    android:padding="4dp">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="3dp"
        android:layout_weight="1.1">
        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/on_display_widget_image_clip"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:outlineProvider="background"
            android:scaleType="centerCrop" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="7dp"
            android:background="@drawable/on_display_widget_pill"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.06"
            android:paddingStart="7dp"
            android:paddingTop="3dp"
            android:paddingEnd="7dp"
            android:paddingBottom="3dp"
            android:text="✦ ON DISPLAY"
            android:textColor="@color/on_display_primary"
            android:textSize="8sp" />
    </FrameLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/on_display_widget_info_mat"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">
        <TextView
            android:id="@+id/widget_series_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="-1dp"
            android:maxLines="2"
            android:textColor="@color/on_display_text"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/widget_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_display_meta"
            android:textSize="8sp" />
        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_display_meta"
            android:textSize="7sp" />
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="3dp"
            android:background="@color/on_display_outline"
            android:contentDescription="@null" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:text="@string/on_display_your_collection"
            android:textColor="@color/on_display_meta"
            android:textSize="7sp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/widget_owned"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_display_meta"
                android:textSize="8sp" />
            <TextView
                android:id="@+id/widget_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/on_display_primary"
                android:textSize="8sp" />
            <TextView
                android:id="@+id/widget_master"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
            android:background="@drawable/on_display_widget_status_badge"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:textColor="@color/on_display_primary"
            android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
