<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/on_display_widget_background"
    android:clipToOutline="true"
    android:orientation="vertical"
    android:outlineProvider="background"
    android:padding="4dp">

    <!-- Region 1: 62% hero cover, clipped by its container. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="62"
        android:background="@drawable/on_display_widget_image_container"
        android:clipToOutline="true"
        android:outlineProvider="background">

        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_gravity="bottom"
            android:background="@drawable/on_display_widget_image_fade"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:background="@drawable/on_display_widget_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:contentDescription="@null"
                android:src="@drawable/on_display_widget_secret" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:text="ON DISPLAY"
                android:textColor="@color/on_display_primary"
                android:textSize="8sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Region 2: 18% compact identity. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="18"
        android:background="@drawable/on_display_widget_large_info_surface"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="3dp"
        android:paddingEnd="14dp"
        android:paddingBottom="3dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="3dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/on_display_transition_line"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_series_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="@color/on_display_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/on_display_primary"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:ellipsize="end"
            android:letterSpacing="0.03"
            android:maxLines="1"
            android:textColor="@color/on_display_brand"
            android:textSize="8sp" />
    </LinearLayout>

    <!-- Region 3: 20% collection summary. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="20"
        android:background="@drawable/on_display_widget_large_info_surface"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="3dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:contentDescription="@null"
                android:src="@drawable/on_display_widget_secret" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:text="@string/on_display_your_collection"
                android:textColor="@color/on_display_primary"
                android:textSize="8sp" />
            <TextView
                android:id="@+id/widget_zero_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/on_display_widget_zero_status_chip"
                android:fontFamily="sans-serif"
                android:paddingStart="8dp"
                android:paddingTop="1dp"
                android:paddingEnd="8dp"
                android:paddingBottom="1dp"
                android:text="@string/on_display_new_on_shelf"
                android:textColor="@color/on_display_primary"
                android:textSize="6.5sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="3dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="1dp"
                android:layout_weight="1"
                android:background="@drawable/on_display_widget_stat_mat"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="5dp"
                android:paddingEnd="5dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/on_display_widget_collection"
                    android:tint="@color/on_display_primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_owned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:textColor="@color/on_display_text"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Figures"
                        android:textColor="@color/on_display_meta"
                        android:textSize="8sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="1dp"
                android:layout_weight="1"
                android:background="@drawable/on_display_widget_stat_mat"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="5dp"
                android:paddingEnd="5dp">
                <ProgressBar
                    android:id="@+id/widget_progress_ring"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/on_display_widget_progress_ring" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:textColor="@color/on_display_text"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete"
                        android:textColor="@color/on_display_meta"
                        android:textSize="8sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_marginTop="1dp"
                android:layout_marginBottom="1dp"
                android:layout_weight="1"
                android:background="@drawable/on_display_widget_stat_mat"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="5dp"
                android:paddingEnd="5dp">
                <ImageView
                    android:id="@+id/widget_third_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/on_display_widget_secret"
                    android:tint="@color/on_display_primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_third_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:textColor="@color/on_display_text"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/widget_third_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_display_meta"
                        android:textSize="8sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
