{
  "name": "blindbox-functions",
  "private": true,
  "description": "Thin market provider gateway — Mercari browse only (no app intelligence).",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "verify:image-embedding": "npm run build && node tools/verify-image-embedding.mjs",
    "embed:catalog-figures": "npm run build && node tools/embed-catalog-figures.mjs",
    "retrieve:catalog-figures": "npm run build && node tools/retrieve-catalog-figures.mjs",
    "evaluate:figure-retrieval": "npm run build && node tools/evaluate-figure-retrieval.mjs",
    "calibrate:figure-retrieval": "npm run build && node tools/calibrate-figure-retrieval.mjs",
    "validate:figure-blur": "npm run build && node tools/validate-figure-blur.mjs",
    "benchmark:figure-blur-metrics": "npm run build && node tools/benchmark-figure-blur-metrics.mjs",
    "audit:coverage": "npm run build && node tools/audit-browse-coverage.mjs",
    "audit:coverage:probe": "npm run build && node tools/audit-browse-coverage.mjs --probe-failures",
    "audit:ecosystem": "npm run build && node tools/audit-ecosystem-calibration.mjs",
    "serve": "npm run build && npx firebase emulators:start --only functions",
    "deploy": "npm run build && npx firebase deploy --only functions:market"
  },
  "dependencies": {
    "@google-cloud/firestore": "8.6.0",
    "@google/genai": "^2.12.0",
    "firebase-admin": "^10.3.0",
    "firebase-functions": "^4.9.0",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "firebase-tools": "^15.18.0",
    "typescript": "^5.7.0"
  }
}
