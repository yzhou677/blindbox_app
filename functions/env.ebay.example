# Copy into .env.blindbox-collection (gitignored) for eBay Browse via market gateway.
# Never commit real Client ID / Secret.
#
MARKET_GATEWAY_PROVIDER=ebay
MARKET_GATEWAY_MODE=live
# Sandbox (default for internal test): Cert ID often starts with SBX-
# Production (after approval): EBAY_ENV=production + Production keys
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Optional:
# EBAY_DEFAULT_QUERY=pop mart blind box
# EBAY_MARKETPLACE_ID=EBAY_US
# EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
# MARKET_GATEWAY_DEBUG=1
